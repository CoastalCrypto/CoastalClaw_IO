#!/bin/sh
# CoastalClaw labwc autostart

# ── First-boot network setup ──────────────────────────────────
# If we can't reach the loopback server yet, check for internet.
# If offline, drop into nmtui so the user can configure WiFi/IP
# before Chromium opens.
if ! curl -sf --max-time 3 http://localhost:4747/health > /dev/null 2>&1; then
  if ! ping -c 1 -W 2 1.1.1.1 > /dev/null 2>&1; then
    # No network — open nmtui in a terminal for WiFi/static IP config
    alacritty \
      --title "Network Setup" \
      -e sh -c 'echo "No network detected. Configure network connection:"; nmtui; echo "Done. Close this window."' &
    # Wait for network to come up (up to 30s)
    for i in $(seq 1 30); do
      ping -c 1 -W 1 1.1.1.1 > /dev/null 2>&1 && break
      sleep 1
    done
  fi
fi

# ── Wait for coastal-server ───────────────────────────────────
# Give systemd up to 15s to bring the server up before Chromium opens
for i in $(seq 1 15); do
  curl -sf --max-time 1 http://localhost:4747/health > /dev/null 2>&1 && break
  sleep 1
done

# ── Launch Waybar ────────────────────────────────────────────
mkdir -p "$HOME/.config/waybar"
cp /opt/coastalclaw/coastalos/waybar/config.jsonc "$HOME/.config/waybar/config"
cp /opt/coastalclaw/coastalos/waybar/style.css    "$HOME/.config/waybar/style.css"
waybar &

# ── Launch Chromium kiosk ─────────────────────────────────────
chromium-browser \
  --kiosk \
  --no-first-run \
  --disable-translate \
  --disable-features=TranslateUI \
  --disable-pinch \
  --overscroll-history-navigation=0 \
  --app=http://localhost:5173 &
