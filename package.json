{
  "name": "coastal-claw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "start": "concurrently --kill-others-on-fail --prefix-colors \"cyan,magenta\" --names \"core,web\" \"node packages/core/dist/index.js\" \"pnpm --filter web dev\"",
    "start:fresh": "pnpm build && pnpm start",
    "stop": "kill $(cat /tmp/coastal-claw-core.pid 2>/dev/null) 2>/dev/null; true",
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
