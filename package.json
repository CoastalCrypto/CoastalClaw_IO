{
  "name": "coastal-claw",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "start": "concurrently --kill-others-on-fail --prefix-colors \"cyan,magenta\" --names \"core,web\" \"node packages/core/dist/main.js\" \"pnpm --filter web dev\"",
    "desktop": "concurrently --kill-others-on-fail --prefix-colors \"cyan,magenta,yellow\" --names \"core,web,shell\" \"pnpm --filter core dev\" \"pnpm --filter web dev\" \"sleep 4 && pnpm --filter shell dev\"",
    "start:fresh": "pnpm build && pnpm start",
    "stop": "kill $(cat /tmp/coastal-claw-core.pid 2>/dev/null) 2>/dev/null; true",
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "@xmldom/xmldom": ">=0.9.9",
      "loader-utils": ">=2.0.4"
    }
  }
}
