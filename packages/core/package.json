{
  "name": "@coastal-ai/core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./architect/types": {
      "types": "./dist/architect/types.d.ts",
      "default": "./dist/architect/types.js"
    },
    "./architect/db": {
      "types": "./dist/architect/db.d.ts",
      "default": "./dist/architect/db.js"
    },
    "./architect/store": {
      "types": "./dist/architect/store.d.ts",
      "default": "./dist/architect/store.js"
    },
    "./architect/cycle-store": {
      "types": "./dist/architect/cycle-store.d.ts",
      "default": "./dist/architect/cycle-store.js"
    },
    "./architect/dedup": {
      "types": "./dist/architect/dedup.d.ts",
      "default": "./dist/architect/dedup.js"
    },
    "./architect/ulid": {
      "types": "./dist/architect/ulid.d.ts",
      "default": "./dist/architect/ulid.js"
    }
  },
  "bin": {
    "coastal-acp": "dist/acp/entry.js"
  },
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');if(fs.existsSync('src/agents/souls'))fs.cpSync('src/agents/souls','dist/agents/souls',{recursive:true});if(fs.existsSync('src/skills/default-skills.json'))fs.copyFileSync('src/skills/default-skills.json','dist/skills/default-skills.json')\"",
    "dev": "node --watch --loader ts-node/esm src/main.ts",
    "acp": "node --loader ts-node/esm src/acp/entry.ts",
    "acp:built": "node dist/acp/entry.js",
    "repair": "node --loader ts-node/esm src/cli/repair.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.0",
    "@apollo/server": "^4.10.0",
    "@dagrejs/graphlib": "^2.2.2",
    "@fastify/cors": "^9.0.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/websocket": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "better-sqlite3": "^11.10.0",
    "croner": "^10.0.1",
    "dotenv": "^16.4.0",
    "fastify": "^4.28.0",
    "graphql": "^16.8.0",
    "mammoth": "^1.12.0",
    "mem0ai": "^2.4.2",
    "nodejs-polars": "^0.24.1",
    "onnxruntime-node": "^1.24.3",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.0",
    "typescript": "~5.9.3",
    "vitest": "^1.6.0",
    "ws": "^8.20.0"
  }
}
